# APP CONFIG
FLASK_ENV=development
APP_ENV=development
SECRET_KEY=change-me
DEBUG=False

# DATABASE
POSTGRES_USER=youruser
POSTGRES_PASSWORD=yourpassword
POSTGRES_DB=pulsequeue
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql://youruser:yourpassword@postgres:5432/pulsequeue

# REDIS
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# WORKER CONFIG
WORKER_POLL_INTERVAL=2
MAX_RETRIES=5
RETRY_BACKOFF_BASE=2